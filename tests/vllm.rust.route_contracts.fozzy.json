{
  "version": 1,
  "name": "vllm-rust-route-contracts",
  "steps": [
    {
      "type": "proc_spawn",
      "cmd": "sh",
      "args": [
        "-c",
        "set -eu\n[ -f vllm/rust/src/server/src/routes.rs ]\n[ -f vllm/rust/src/server/src/routes/http_client_tests.rs ]\nrg -n '/health|/v1/models|/v1/completions|/v1/chat/completions|/tokenize|/detokenize' vllm/rust/src/server/src/routes.rs >/dev/null\nprintf 'vllm-rust-route-contracts\\n'"
      ],
      "expect_exit": 0,
      "expect_stdout": "vllm-rust-route-contracts\n",
      "expect_stderr": ""
    }
  ]
}
